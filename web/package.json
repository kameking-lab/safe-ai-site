{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate --no-hints || true",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:failure": "playwright test --grep @failure",
    "test:e2e:recovery": "playwright test --grep @recovery",
    "test:e2e:ci": "CI=1 playwright test",
    "test:live": "NEXT_PUBLIC_API_MODE=live playwright test",
    "check:ci": "npm run lint && npm run build && npm run test && npm run test:e2e:ci",
    "vercel:whoami": "vercel whoami",
    "vercel:link": "vercel link --yes --cwd .",
    "vercel:preview": "vercel deploy --yes --cwd .",
    "vercel:prod": "vercel deploy --prod --yes --cwd .",
    "capture": "node ../scripts/capture-screenshots.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.3",
    "@stripe/stripe-js": "^9.1.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@vercel/blob": "^2.3.3",
    "d3-geo": "^3.1.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.1",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^50.37.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
