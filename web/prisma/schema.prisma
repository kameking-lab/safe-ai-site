// NextAuth標準スキーマ + サブスクリプション。
// DATABASE_URL未設定時はクライアント側でnullを返してDB操作をスキップ。
// 参考: https://authjs.dev/getting-started/adapters/prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  planName             String    @default("free")
  status               String    @default("active")
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// 資格別100問クイズの問題（モックデータからシード可能）。
model ExamQuestion {
  id            String   @id @default(cuid())
  /// 資格スラッグ（例: "health-1st"）
  examSlug      String
  /// 問題番号（資格内の連番）
  number        Int
  question      String   @db.Text
  /// 4択選択肢（["...","...","...","..."]）
  choices       Json
  /// 正解インデックス（0..3）
  correctAnswer Int
  explanation   String   @db.Text
  /// 法令根拠等（["安衛則36条","..."]）
  lawRefs       Json?
  difficulty    String   @default("標準")
  topic         String?

  @@unique([examSlug, number])
  @@index([examSlug])
}

/// 資格別クイズの受験記録（プラン別の弱点分析・PDF出力に使用）。
model ExamAttempt {
  id        String   @id @default(cuid())
  userId    String
  examSlug  String
  /// 正解数
  score     Int
  /// 受験回答（[{questionId,selected,correct,topic,difficulty}]）
  answers   Json
  createdAt DateTime @default(now())

  @@index([userId, examSlug, createdAt])
}

/// Stripe Webhookイベントの処理済み記録。冪等性確保のために使用。
model StripeEvent {
  id           String   @id @default(cuid())
  stripeEventId String  @unique
  eventType    String
  processedAt  DateTime @default(now())

  @@index([stripeEventId])
}

/// SDS検索＋RA自動実行の履歴。/account から閲覧可能。
model SdsSearch {
  id            String   @id @default(cuid())
  userId        String?
  productName   String
  manufacturer  String?
  ventilation   String
  amount        String
  durationHours Float
  /// 検索でヒットした製品（NITE-CHRIPまたは内蔵DB）。primaryHit があれば JSON
  productHit    Json?
  /// 全体リスクレベル: I, II, III, IV
  riskLevel     String?
  /// 各成分のRA結果（[{ cas, name, level, exposure, ... }]）
  componentRa   Json?
  source        String   @default("internal-db")
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}
