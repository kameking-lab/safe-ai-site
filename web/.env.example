# ============================================================
# ANZEN AI — .env.example
# 正式な変数名一覧。命名ガイド: docs/env-naming-guide-2026-05-02.md
# ============================================================

# --- アフィリエイト（ブラウザ公開） ---
# Amazon アソシエイトタグ（例: safeaisite22-22）
NEXT_PUBLIC_AMAZON_AFFILIATE_ID=
# 後方互換のため旧名 NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG も認識します
# 楽天アフィリエイトID（hb.afl.rakuten.co.jp 経由のリダイレクトに使用）
NEXT_PUBLIC_RAKUTEN_AFFILIATE_ID=

# --- 認証 (NextAuth v5) ---
# openssl rand -base64 32 で生成
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- AI (Gemini) ---
# https://aistudio.google.com/app/apikey から取得
# ローテーション手順: docs/gemini-rotation-guide.md
GEMINI_API_KEY=

# --- Vercel Blob ストレージ ---
# ローテーション手順: docs/blob-rotation-guide.md
BLOB_READ_WRITE_TOKEN=

# --- メール通知 (Resend) ---
# Resend ダッシュボード > API Keys で取得
RESEND_API_KEY=
# 送信元アドレス（例: ANZEN AI <noreply@anzen-ai.com>）
NOTIFY_FROM=
# 気象警報通知用オーディエンスID（notify/subscribe API が使用）
RESEND_AUDIENCE_ID=
# 週間メルマガ専用オーディエンスID（subscribe API が使用）
NEWSLETTER_AUDIENCE_ID=
# 管理画面 API のアクセストークン（未設定時は認証なし）
NEWSLETTER_ADMIN_TOKEN=

# --- Cron ジョブ認証 ---
# openssl rand -hex 32 で生成
CRON_SECRET=

# --- Stripe 決済 ---
# 判断基準: docs/stripe-env-decision.md
STRIPE_SECRET_KEY=
# Development: stripe listen で発行される whsec_xxx を使用
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=
NEXT_PUBLIC_STRIPE_PRICE_PRO=

# --- サイト設定 ---
# 本番: https://safe-ai-site.vercel.app
NEXT_PUBLIC_SITE_URL=
# お問い合わせフォーム (省略可。未設定時はメーラー起動)
NEXT_PUBLIC_FORMSPREE_ID=

# --- DB (Prisma / Postgres) ---
# 省略可。未設定時はDB機能が無効
DATABASE_URL=

# --- Google Search Console ---
# 省略可。GSCでプロパティ登録後に設定（layout.tsx に直書きも可）
NEXT_PUBLIC_GSC_VERIFICATION=

# --- 機能フラグ ---
# 課金機能フラグ。将来の課金実装時に true に変更
NEXT_PUBLIC_PAID_MODE=false
# 法改正データソース: "sample"(モック) or "real"(実データ)
NEXT_PUBLIC_REVISIONS_INGEST_SOURCE=sample
# 法改正リアルデータURL (real モード時のみ必要)
REVISIONS_REAL_SOURCE_URL=

# --- デバッグ専用 (Development のみ) ---
# NEXT_PUBLIC_FORCE_ERROR=
# NEXT_PUBLIC_FORCE_ERROR_TRANSPORT=
