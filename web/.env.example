NEXT_PUBLIC_API_MODE=mock
NEXT_PUBLIC_REVISIONS_INGEST_SOURCE=sample
# server-side real ingest source URL（httpsのみ）
# REVISIONS_REAL_SOURCE_URL=https://api.example.com/revisions.json
# 許可ホスト（カンマ区切り、サブドメイン許可）
# REVISIONS_REAL_SOURCE_ALLOW_HOSTS=example.com,api.example.jp
# 取得元フォーマット（default | official-db）
# REVISIONS_REAL_SOURCE_FORMAT=official-db
CI=true
# 共通失敗注入（任意）: 5xx | timeout | validation
# NEXT_PUBLIC_FORCE_ERROR=5xx
# 注入方式（任意）: query | header
# NEXT_PUBLIC_FORCE_ERROR_TRANSPORT=header

# 天気リスクAPI（liveモードで使用、任意）
# NEXT_PUBLIC_WEATHER_API_MODE=live
# NEXT_PUBLIC_WEATHER_API_TIMEOUT_MS=4500

# ingest real 注入（任意）:
# NEXT_PUBLIC_REVISIONS_INGEST_SOURCE=real
# REVISIONS_REAL_SOURCE_PAYLOAD_JSON=[{"id":"real-1","title":"実データ例","published_at":"2026-01-01","summary":"概要"}]

# E2Eでquery注入を使う場合の例（URL側で指定）
# ?forceErrorTransport=header
# ?forceRevisionsError=5xx
# ?forceSummaryError=timeout
# ?forceChatError=validation
