# ブラウザに公開されるアフィリエイト用ID（秘密鍵はここに書かない）
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=
NEXT_PUBLIC_RAKUTEN_AFID=

# NextAuth v5 認証（省略可。未設定時は認証機能が無効になります）
# openssl rand -base64 32 で生成してください
AUTH_SECRET=

# Google OAuth（省略可。認証機能を使う場合のみ設定）
# Google Cloud Console > 認証情報 > OAuthクライアントID で取得
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Formspree（省略可。未設定時はメーラー起動にフォールバックします）
NEXT_PUBLIC_FORMSPREE_ID=

# フィードバックフォームURL（省略可。未設定時はお問い合わせページへ誘導）
NEXT_PUBLIC_FEEDBACK_FORM_URL=

# Google Search Console 所有権確認トークン（省略可。GSCでプロパティ登録後に設定）
# layout.tsx の verification コメントアウトを外してから使用
NEXT_PUBLIC_GSC_VERIFICATION=

# Prisma / Postgres（省略可。未設定時はDB機能が無効）
# Vercel Postgres インスタンスのプール接続URLを推奨
DATABASE_URL=

# Stripe決済（省略可。未設定時は決済機能が無効）
# Stripeダッシュボード > 開発者 から取得
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# サブスクリプション価格ID
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
# 本番サイトURL（Stripe Checkout の success/cancel URL に使用）
NEXT_PUBLIC_SITE_URL=
