# Google Gemini API Key
# https://aistudio.google.com/app/apikey から取得
GEMINI_API_KEY=

# Amazon アソシエイトタグ
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=

# 楽天アフィリエイトID
NEXT_PUBLIC_RAKUTEN_AFFILIATE_ID=

# 課金UI表示モード
# 研究・実証プロジェクト期間中は false（全課金UIを非表示）。
# M6 で課金事業を再開する際は "true" に変更すると Pro/Business/Stripe 等が復活する。
NEXT_PUBLIC_PAID_MODE=false

